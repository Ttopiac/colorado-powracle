# ── Secrets — never commit ────────────────────────────────────────────────────
.env
*.env

# ── Generated data files — regenerate locally with setup scripts ──────────────
# See README.md → Installation for how to recreate these
data/
*.duckdb
*.parquet

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/

# ── OS / editor clutter ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Personal / planning docs — never push ────────────────────────────────────
plans/
ttopiac/

# ── Eval runtime outputs — regenerate locally, keep baselines in eval/baselines/
eval/results/

# ── Misc files not needed on GitHub ──────────────────────────────────────────
*.zip

# ── Streamlit secrets (keep config.toml, ignore secrets.toml) ────────────────
.streamlit/secrets.toml

# ── Markdown files — keep README + AI agent context files + GitHub templates ──
*.md
!README.md
!CLAUDE.md
!**/CLAUDE.md
!AGENTS.md
!docs/*.md
!.github/pull_request_template.md
!eval/baselines/*.md
!.claude/skills/**/*.md
